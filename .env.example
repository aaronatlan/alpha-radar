# === Alpha Radar — Variables d'environnement ===
# Copier ce fichier en .env et ajuster. Ne jamais commiter .env.

# Environnement
ALPHA_ENV=development           # development | production
ALPHA_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# Stockage
ALPHA_DB_PATH=data/alpha_radar.db
ALPHA_DATA_DIR=data

# --- Phase 1 : aucune clé API requise (arXiv et yfinance sont publics). ---
# --- Phases suivantes : décommenter au fur et à mesure. Toutes les ---
# --- variables portent le préfixe ALPHA_ — pydantic-settings ignore ---
# --- silencieusement les noms bruts (GITHUB_TOKEN, NEWSAPI_KEY, …). ---
# ALPHA_GITHUB_TOKEN=
# ALPHA_SEC_USER_AGENT=Nom Prénom votre.email@example.com
# ALPHA_NEWSAPI_KEY=
# ALPHA_ADZUNA_APP_ID=
# ALPHA_ADZUNA_APP_KEY=

# --- Alertes email (Phase 3) ---
# Tous les champs SMTP sont optionnels — sans configuration, le moteur
# d'alertes écrit en base mais n'envoie pas d'email.
# ALPHA_SMTP_HOST=smtp.gmail.com
# ALPHA_SMTP_PORT=587
# ALPHA_SMTP_USER=alerts@example.com
# ALPHA_SMTP_PASSWORD=an_app_password_not_your_real_one
# ALPHA_SMTP_FROM=alerts@example.com
# ALPHA_SMTP_TO=you@example.com
# ALPHA_SMTP_USE_TLS=true
