# === Alpha Radar — Variables d'environnement ===
# Copier ce fichier en .env et ajuster. Ne jamais commiter .env.

# Environnement
ALPHA_ENV=development           # development | production
ALPHA_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# Stockage
ALPHA_DB_PATH=data/alpha_radar.db
ALPHA_DATA_DIR=data

# --- Phase 1 : aucune clé API requise (arXiv et yfinance sont publics). ---
# --- Phases suivantes : décommenter au fur et à mesure. ---
# GITHUB_TOKEN=
# SEC_EDGAR_USER_AGENT=votre.email@example.com
# NEWSAPI_KEY=
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
